# Generate with: python -c "import secrets; print(secrets.token_urlsafe())"
DJANGO_SECRET_KEY=change-me

# Set to True for local dev
PASSPORT_DEBUG=True

# OAuth client values from Meta-Wiki OAuth consumer registration
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Override if you want a different authorization server
OAUTH_AUTHORIZATION_SERVER=https://www.wikidata.org

# Optional overrides
# OAUTH_ACCESS_TOKEN_URL=https://www.wikidata.org/w/rest.php/oauth2/access_token
# OAUTH_AUTHORIZATION_URL=https://www.wikidata.org/w/rest.php/oauth2/authorize
# OAUTH_PROFILE_URL=https://www.wikidata.org/w/rest.php/oauth2/resource/profile

# Wikidata Query Service endpoint
WIKIDATA_QUERY_ENDPOINT=https://query.wikidata.org/sparql

# Toolforge hostname
ALLOWED_HOSTS=checklist.toolforge.org,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://checklist.toolforge.org,http://localhost:8000
